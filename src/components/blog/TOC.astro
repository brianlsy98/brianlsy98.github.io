---
import type { MarkdownHeading } from "astro";
import { generateToc } from "@/utils/generateToc";
import TOCHeading from "./TOCHeading.astro";

interface Props {
	headings: MarkdownHeading[];
}

const { headings } = Astro.props;

const toc = generateToc(headings);
---

<details open class="toc-docked lg:w-64">
	<summary class="toc-summary title cursor-pointer text-lg">Table of Contents</summary>
	<nav class="ms-4 lg:ms-0 lg:w-full">
		<ul class="mt-4 list-disc ps-5">
			{toc.map((heading) => <TOCHeading heading={heading} />)}
		</ul>
	</nav>
</details>

<script>
	const tocEl = document.querySelector("details.toc-docked") as HTMLDetailsElement | null;

	function syncTocPosition() {
		if (!tocEl) return;
		if (window.innerWidth < 1024) {
			tocEl.style.removeProperty("top");
			return;
		}

		const titleEl = document.querySelector("#blog-hero .title, #blog-hero h1") as HTMLElement | null;
		const themeToggleEl = document.querySelector(
			"theme-toggle.theme-toggle-docked",
		) as HTMLElement | null;

		const buttonTop = Math.round(themeToggleEl?.getBoundingClientRect().top ?? 73);
		const titleTop = Math.round(titleEl?.getBoundingClientRect().top ?? buttonTop);

		// Start at the title line, then clamp to the theme-toggle line while scrolling.
		tocEl.style.top = `${Math.max(buttonTop, titleTop)}px`;
	}

	window.addEventListener("load", syncTocPosition);
	window.addEventListener("resize", syncTocPosition);
	window.addEventListener("scroll", syncTocPosition, { passive: true });
	syncTocPosition();
</script>

<style>
	:global(details.toc-docked > summary.toc-summary) {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		list-style: none;
	}

	:global(details.toc-docked > summary.toc-summary::-webkit-details-marker) {
		display: none;
	}

	:global(details.toc-docked > summary.toc-summary::marker) {
		content: "";
	}

	:global(details.toc-docked > summary.toc-summary::after) {
		content: "";
		width: 0.5rem;
		height: 0.5rem;
		border-right: 1.5px solid currentColor;
		border-bottom: 1.5px solid currentColor;
		transform: rotate(-45deg) translateY(-1px);
		transition: transform 0.2s ease;
	}

	:global(details.toc-docked[open] > summary.toc-summary::after) {
		transform: rotate(45deg) translateY(-1px);
	}

	@media (min-width: 1024px) {
		:global(details.toc-docked) {
			position: fixed;
			top: 4.55rem;
			left: max(1.25rem, calc((100vw - 52.8rem) / 2 - 14rem));
			max-height: none;
			overflow: visible;
			z-index: 40;
		}
	}
</style>
