---
import { type CollectionEntry } from "astro:content";
import PublicationCard from "@/components/publication/PublicationCard.astro";
import SocialList from "@/components/SocialList.astro";
import { getAllPosts } from "@/data/post";
import { researchPapers } from "@/data/publication";
import PageLayout from "@/layouts/Base.astro";
import { collectionDateSort } from "@/utils/date";

// Posts
const MAX_POSTS = 5;
const allPosts = await getAllPosts();
const allPostsByDate = allPosts.sort(collectionDateSort) as CollectionEntry<"post">[];
const latestPosts = allPostsByDate.slice(0, MAX_POSTS);

const selectedPublicationTitles = new Set([
	"DICE: Device-level Integrated Circuits Encoder with Graph Contrastive Pretraining",
	"Towards Efficient and Expressive Offline RL via Flow Anchored Noise-conditioned Q-Learning",
]);

const selectedPublications = researchPapers.filter((paper) =>
	selectedPublicationTitles.has(paper.title),
);
---

<PageLayout
	meta={{
		title: "Sungyoung Lee",
		description:
			"I work on improving the efficiency of expressive machine learning (ML) algorithms.",
	}}
>
	<section class="grid items-start gap-8 sm:grid-cols-[180px_1fr]">
		<div class="mx-auto flex flex-col items-center sm:mx-0 sm:block">
			<img
				alt="Portrait of LSY Blog"
				class="h-56 w-56 rounded-2xl border border-zinc-300 object-cover shadow-sm sm:h-48 sm:w-48 dark:border-zinc-700"
				height="224"
				src="/sungyoung.jpg"
				width="224"
			/>
		</div>
		<div>
			<h1 class="title mb-4"><span class="text-accent">Sungyoung</span> Lee</h1>
			<p class="mb-2">
				Hi all, welcome!
			</p>
			<p class="mb-2">
				I work on efficient algorithms and systems for Robotics.
				<br />
				Particularly, I am interested in <strong class="text-accent">Reinforcement Learning</strong> and <strong
					class="text-accent">GPU Programming</strong
				>.
			</p>
			<p class="mb-2">
				Check out <a class="cactus-link" href="/about/">About</a> for more details!
			</p>
			<div class="mt-4">
				<SocialList />
			</div>
		</div>
	</section>
	<section class="mt-16">
		<h2 class="title text-accent mb-6 text-xl">
			<a href="/posts/">Blog</a>
		</h2>
		<ul class="grid gap-4 sm:grid-cols-2" role="list">
			{
				latestPosts.map((post) => (
					<li class="rounded-xl border border-zinc-300 p-4 dark:border-zinc-700">
						<h3 class="font-semibold">
							<a class="cactus-link" href={`/posts/${post.id}/`}>
								{post.data.title}
							</a>
						</h3>
						<p class="mt-2 text-sm opacity-80">{post.data.description}</p>
					</li>
				))
			}
		</ul>
	</section>
	<section class="mt-16">
		<h2 class="title text-accent mb-6 text-xl">
			<a href="/publications/">Selected Publications</a>
		</h2>
		<ul class="space-y-6" role="list">
			{
				selectedPublications.map((paper) => (
					<li class="rounded-xl border border-zinc-300 p-4 dark:border-zinc-700">
						<PublicationCard paper={paper} enlargeSvgFigure linksBelowSummary />
					</li>
				))
			}
		</ul>
		<p class="mt-4 text-sm sm:text-end">
			<a class="cactus-link" href="/publications/">View all publications →</a>
		</p>
	</section>
<script>
	// Mobile browsers can fail to re-evaluate SVG light/dark colors after a theme toggle.
	// Force a lightweight SVG refresh on theme/data-theme changes.
	let publicationSvgRevision = Date.now();

	function syncPublicationSvgTheme(forceRefresh = false, themeOverride?: string) {
		const theme =
			themeOverride === "dark" || themeOverride === "light"
				? themeOverride
				: document.documentElement.getAttribute("data-theme") === "dark"
					? "dark"
					: "light";

		const svgImages = document.querySelectorAll<HTMLImageElement>("img[data-publication-svg='true']");

		if (forceRefresh) {
			publicationSvgRevision += 1;
		}

		svgImages.forEach((img) => {
			const baseSrc = img.dataset.svgBaseSrc ?? img.getAttribute("src");

			if (!baseSrc) {
				return;
			}

			img.dataset.svgBaseSrc = baseSrc;
			// Ensure embedded SVG color-scheme follows the active site theme on mobile + desktop.
			img.style.setProperty("color-scheme", theme);

			const svgUrl = new URL(baseSrc, window.location.href);
			svgUrl.searchParams.set("theme", theme);
			svgUrl.searchParams.set("rev", String(publicationSvgRevision));
			img.src = `${svgUrl.pathname}${svgUrl.search}${svgUrl.hash}`;
		});
	}

	const windowWithPublicationSvgHandlers = window as Window & {
		__homePublicationSvgAfterSwapHandler__?: () => void;
		__homePublicationSvgThemeHandler__?: (event?: Event) => void;
		__homePublicationSvgThemeObserver__?: MutationObserver;
	};

	if (windowWithPublicationSvgHandlers.__homePublicationSvgThemeHandler__) {
		document.removeEventListener(
			"theme-change",
			windowWithPublicationSvgHandlers.__homePublicationSvgThemeHandler__,
		);
	}

	if (windowWithPublicationSvgHandlers.__homePublicationSvgAfterSwapHandler__) {
		document.removeEventListener(
			"astro:after-swap",
			windowWithPublicationSvgHandlers.__homePublicationSvgAfterSwapHandler__,
		);
	}

	if (windowWithPublicationSvgHandlers.__homePublicationSvgThemeObserver__) {
		windowWithPublicationSvgHandlers.__homePublicationSvgThemeObserver__.disconnect();
	}

	windowWithPublicationSvgHandlers.__homePublicationSvgThemeHandler__ = (event?: Event) => {
		const nextTheme =
			event instanceof CustomEvent && (event.detail?.theme === "dark" || event.detail?.theme === "light")
				? event.detail.theme
				: undefined;
		syncPublicationSvgTheme(true, nextTheme);
	};
	windowWithPublicationSvgHandlers.__homePublicationSvgAfterSwapHandler__ = () =>
		syncPublicationSvgTheme(true);

	document.addEventListener(
		"theme-change",
		windowWithPublicationSvgHandlers.__homePublicationSvgThemeHandler__,
	);
	document.addEventListener(
		"astro:after-swap",
		windowWithPublicationSvgHandlers.__homePublicationSvgAfterSwapHandler__,
	);

	windowWithPublicationSvgHandlers.__homePublicationSvgThemeObserver__ = new MutationObserver(() =>
		syncPublicationSvgTheme(true),
	);
	windowWithPublicationSvgHandlers.__homePublicationSvgThemeObserver__.observe(document.documentElement, {
		attributes: true,
		attributeFilter: ["data-theme"],
	});

	syncPublicationSvgTheme(true);
</script>

</PageLayout>
