---
import { type CollectionEntry } from "astro:content";
import PublicationCard from "@/components/publication/PublicationCard.astro";
import SocialList from "@/components/SocialList.astro";
import { getAllPosts } from "@/data/post";
import { researchPapers } from "@/data/publication";
import PageLayout from "@/layouts/Base.astro";
import { collectionDateSort } from "@/utils/date";

// Posts
const MAX_POSTS = 5;
const allPosts = await getAllPosts();
const allPostsByDate = allPosts.sort(collectionDateSort) as CollectionEntry<"post">[];
const latestPosts = allPostsByDate.slice(0, MAX_POSTS);

const selectedPublicationTitles = new Set([
	"DICE: Device-level Integrated Circuits Encoder with Graph Contrastive Pretraining",
	"Towards Efficient and Expressive Offline RL via Flow Anchored Noise-conditioned Q-Learning",
]);

const selectedPublications = researchPapers.filter((paper) =>
	selectedPublicationTitles.has(paper.title),
);
---

<PageLayout
	meta={{
		title: "Sungyoung Lee",
		description:
			"I work on improving the efficiency of expressive machine learning (ML) algorithms.",
	}}
>
	<section class="grid items-start gap-8 sm:grid-cols-[180px_1fr]">
		<div class="mx-auto flex flex-col items-center sm:mx-0 sm:block">
			<img
				alt="Portrait of LSY Blog"
				class="h-56 w-56 rounded-2xl border border-zinc-300 object-cover shadow-sm sm:h-48 sm:w-48 dark:border-zinc-700"
				height="224"
				src="/sungyoung.jpg"
				width="224"
			/>
		</div>
		<div>
			<h1 class="title mb-4"><span class="text-accent">Sungyoung</span> Lee</h1>
			<p class="mb-2">
				Hi all, welcome!
			</p>
			<p class="mb-2">
				I work on efficient algorithms and systems for Robotics.
				<br />
				Particularly, I am interested in Reinforcement Learning and GPU Programming.
			</p>
			<p class="mb-2">
				Check out <a class="cactus-link" href="/about/">About</a> for more details!
			</p>
			<div class="mt-4">
				<SocialList />
			</div>
		</div>
	</section>
	<section class="mt-16">
		<h2 class="title text-accent mb-6 text-xl">
			<a href="/posts/">Blog</a>
		</h2>
		<ul class="grid gap-4 sm:grid-cols-2" role="list">
			{
				latestPosts.map((post) => (
					<li class="rounded-xl border border-zinc-300 p-4 dark:border-zinc-700">
						<h3 class="font-semibold">
							<a class="cactus-link" href={`/posts/${post.id}/`}>
								{post.data.title}
							</a>
						</h3>
						<p class="mt-2 text-sm opacity-80">{post.data.description}</p>
					</li>
				))
			}
		</ul>
	</section>
	<section class="mt-16">
		<h2 class="title text-accent mb-6 text-xl">
			<a href="/publications/">Selected Publications</a>
		</h2>
		<ul class="space-y-6" role="list">
			{
				selectedPublications.map((paper) => (
					<li class="rounded-xl border border-zinc-300 p-4 dark:border-zinc-700">
						<PublicationCard paper={paper} enlargeSvgFigure linksBelowSummary />
					</li>
				))
			}
		</ul>
		<p class="mt-4 text-sm sm:text-end">
			<a class="cactus-link" href="/publications/">View all publications →</a>
		</p>
	</section>
</PageLayout>
